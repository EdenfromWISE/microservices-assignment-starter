# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=
ENVIRONMENT=

# --- Database (adjust to your chosen DB) ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- Service Ports ---
RENTAL_SERVICE_PORT=
PAYMENT_SERVICE_PORT=
DAMAGE_SERVICE_PORT=
GATEWAY_PORT=
FRONTEND_PORT=

# --- RabbitMQ ---
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# --- Add more variables as needed for your stack ---
# REDIS_URL=redis://redis:6379
# RABBITMQ_URL=amqp://rabbitmq:5672
# JWT_SECRET=your-jwt-secret
