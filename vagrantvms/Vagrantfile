# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.box_version = "20241002.0.0"

  # ── Network ──────────────────────────────────────────────────────────
  config.vm.network "private_network", ip: "192.168.33.15"

  # Gateway (main entry point)
  config.vm.network "forwarded_port", guest: 8080, host: 8080
  # Frontend
  config.vm.network "forwarded_port", guest: 3000, host: 3000
  # Services (direct access for debugging)
  config.vm.network "forwarded_port", guest: 8081, host: 8081
  config.vm.network "forwarded_port", guest: 8082, host: 8082
  config.vm.network "forwarded_port", guest: 8083, host: 8083
  # RabbitMQ management UI
  config.vm.network "forwarded_port", guest: 15672, host: 15672

  # ── Synced folder ─────────────────────────────────────────────────────
  # Sync project root (one level up from vagrantvms/) into the VM
  config.vm.synced_folder "..", "/home/vagrant/app"

  # ── Resources ─────────────────────────────────────────────────────────
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "microservices-assignment"
    vb.memory = "4096"
    vb.cpus   = 2
  end

  # ── Provisioning: Docker + Docker Compose ─────────────────────────────
  config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "==> Installing Docker..."
    curl -fsSL https://get.docker.com -o get-docker.sh
    sh get-docker.sh
    usermod -aG docker vagrant

    echo "==> Installing Docker Compose plugin..."
    apt-get install -y docker-compose-plugin

    echo "==> Done. Run: cd /home/vagrant/app && docker compose up --build"
  SHELL
end
